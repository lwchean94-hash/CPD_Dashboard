        "onRender": "const compoundingUid = \"ffm0zswx4jsowa\";\n\nfor (let i = 1; i <= 9; i++) {\n  const btn = htmlNode.getElementById(`page${i}`);\n\n  if (btn) {\n    btn.setAttribute(\n      \"href\",\n      `/foresight/d/${compoundingUid}/all-plant-main-dashboard?orgId=1&from=now-6h&to=now&timezone=browser&var-plantNo=${i}`\n    );\n  }\n}\n\n\n\n//const compoundingUid = \"ad9dfvq\"; // your main compounding dashboard UID\n\n//for (let i = 1; i <= 9; i++) {\n  //const btn = htmlNode.getElementById(`page${i}`);\n  //if (btn) {\n   // btn.setAttribute(\n     // \"href\",\n      //`foresight/d/${compoundingUid}/all-plant-main-dashboard?orgId=1&from=now-6h&to=now&timezone=browser&var-plantNo=${i}`\n   // );\n // }\n//}\n\n",
