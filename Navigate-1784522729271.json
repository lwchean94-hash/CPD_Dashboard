        "dynamicHtmlGraphics": false,
        "dynamicProps": false,
        "html": "<div>\n  \n \n    <div id=\"dropdown_panel\" style=\"display: block;\">\n\n        <div style=\"text-align: center; margin-bottom: 20px;\">\n            <h2 style=\"\n                color: #ffffff;\n                font-family: 'Orbitron', sans-serif;\n                letter-spacing: 1px;\n                font-weight: 600;\n            \">\n                COMPOUNDING SYSTEM NAVIGATION\n            </h2>\n        </div>\n        <div class=\"outer_grid_container\">\n           \n             \n             <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page1\">\n                        Plant 1\n                    </a>\n                </div>\n            </div>\n             <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page2\">\n                        Plant 2\n                    </a>\n                </div>\n            </div>\n             <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page3\">\n                        Plant 3\n                    </a>\n                </div>\n            </div>\n             <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page4\">\n                        Plant 4\n                    </a>\n                </div>\n            </div>\n             <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page5\">\n                        Plant 5\n                    </a>\n                </div>\n            </div>\n             <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page6\">\n                        Plant 6\n                    </a>\n                </div>\n            </div>\n            <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page7\">\n                        Plant 7\n                    </a>\n                </div>\n            </div>\n            <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page8\">\n                        Plant 8\n                    </a>\n                </div>\n            </div>\n            <div class=\"rect\" style=\"background-color: #156082;\">\n                <div class=\"container\">\n                    <a class=\"btn-link items\" id=\"page9\">\n                        Plant 9\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>",
        "onInit": "",
